// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"  
}

model Experiment {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  samples     Sample[]
  createdAt   DateTime  @default(now())
}

model Sample {
  id            Int           @id @default(autoincrement())
  name          String
  sourcefile    String
  processed     Boolean       @default(false)
  experiment    Experiment    @relation(fields: [experimentId], references: [id])
  experimentId  Int
  epsilon_25    Decimal?
  epsilon_50    Decimal?
  epsilon_max   Decimal?
  epsilon_u     Decimal?
  sigma_25      Decimal?
  sigma_50      Decimal?
  sigma_max     Decimal?
  sigma_u       Decimal?
  data          SampleData[]
  createdAt     DateTime      @default(now())
}

model SampleData {
  id            Int         @id @default(autoincrement())
  strain        Decimal
  stress        Decimal
  sample        Sample      @relation(fields: [sampleId], references: [id])
  sampleId      Int
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  name      String?
  password  String
}
